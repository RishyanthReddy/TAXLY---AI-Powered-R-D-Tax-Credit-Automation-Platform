# API Keys
# OpenRouter API Key for DeepSeek reasoning via OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Clockify API Key for time tracking data
CLOCKIFY_API_KEY=your_clockify_api_key_here
CLOCKIFY_WORKSPACE_ID=your_clockify_workspace_id_here

# Unified.to API Key and Workspace for HRIS data
UNIFIED_TO_API_KEY=your_unified_to_api_key_here
UNIFIED_TO_WORKSPACE_ID=your_unified_to_workspace_id_here

# You.com API Key for search and agent capabilities
YOUCOM_API_KEY=your_youcom_api_key_here

# Thesys API Key for UI generation
THESYS_API_KEY=your_thesys_api_key_here

# Playwright MCP Endpoint for web scraping
PLAYWRIGHT_MCP_ENDPOINT=your_playwright_mcp_endpoint_here

# Application Settings
LOG_LEVEL=INFO
MAX_RETRIES=3
TIMEOUT_SECONDS=30

# RAG Configuration
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K_RESULTS=3

# Confidence Thresholds
CONFIDENCE_THRESHOLD_LOW=0.7
CONFIDENCE_THRESHOLD_MEDIUM=0.8
CONFIDENCE_THRESHOLD_HIGH=0.9
